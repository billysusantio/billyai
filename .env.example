# ---- Fonnte (unofficial WhatsApp API) ----
# Get from https://fonnte.com device dashboard
FONNTE_TOKEN=your-fonnte-device-token

# ---- Anthropic / Claude (BillyAI's brain) ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# Model that powers BillyAI's replies (sonnet = fast + capable, good default for chat)
BILLY_MODEL=claude-sonnet-4-6

# ---- Server ----
PORT=3000

# Optional shared secret: Fonnte can append ?secret=... to the webhook URL.
# If set, inbound webhooks missing this value are rejected.
WEBHOOK_SECRET=

# Timezone used by the reminder scheduler (IANA name)
TZ=Asia/Jakarta
